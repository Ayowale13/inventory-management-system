# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_APP=run.py
FLASK_ENV=production

# ── Security ──────────────────────────────────────────────────────────────────
# Generate a strong key:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-this-with-a-long-random-string

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (local dev / Render without a database add-on):
DATABASE_URL=sqlite:///instance/inventory.db

# PostgreSQL (Render PostgreSQL add-on — Render injects this automatically
# when you link a database; no manual edit needed):
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Optional ──────────────────────────────────────────────────────────────────
# Set to "true" to write rotating log files under ./logs/ in addition to stdout
LOG_TO_FILE=false
